{
  "name": "markit-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:type-aware": "oxlint --type-aware",
    "typecheck": "bun run lint:type-aware",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "verify": "bun run fmt:check && bun run lint:type-aware && bun run build",
    "deploy": "bun run verify && wrangler deploy -c dist/server/wrangler.json"
  },
  "dependencies": {
    "@gravity-ui/icons": "^2.20.0",
    "@heroui/react": "^3.2.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "ai": "^7.0.22",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@cloudflare/vite-plugin": "^1.43.2",
    "@cloudflare/workers-types": "^5.20260711.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.23.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wrangler": "^4.108.0"
  },
  "packageManager": "bun@1.4.0"
}
